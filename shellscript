13. Decimal ↔ Binary Converter — 13_decimal_binary.sh
bash#!/bin/bash
echo "1. Decimal→Binary  2. Binary→Decimal"
read -p "Choice: " choice
case $choice in
    1) read -p "Decimal: " dec; num=$dec; binary=""
       while [ $num -gt 0 ]; do binary="$(( num%2 ))$binary"; num=$(( num/2 )); done
       echo "Binary: $binary" ;;
    2) read -p "Binary: " bin; decimal=0
       for (( i=0; i<${#bin}; i++ )); do decimal=$(( decimal*2 + ${bin:$i:1} )); done
       echo "Decimal: $decimal" ;;
esac
45 → 101101 | 101101 → 45 ✓

