15. Sum of N Even Numbers (with Function) — 15_sum_even.sh
bash#!/bin/bash
# Usage: bash 15_sum_even.sh <limit>
sum_even_numbers() {
    local n=$1; local sum=0; local num=2
    for (( count=0; count<n; count++ )); do
        echo -n "$num "
        sum=$(( sum + num )); num=$(( num+2 ))
    done
    echo; echo "Sum of first $n even numbers = $sum"
}
sum_even_numbers $1
