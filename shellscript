4. Linear Search in Array — 4_linear_search.sh
bash#!/bin/bash
read -p "Number of elements: " n
arr=()
for (( i=0; i<n; i++ )); do read -p "Element $((i+1)): " e; arr+=($e); done
read -p "Search for: " target

found=0
for (( i=0; i<n; i++ )); do
    if [ "${arr[$i]}" -eq "$target" ]; then
        echo "Found at index $i (position $((i+1)))"; found=1
    fi
done
[ $found -eq 0 ] && echo "Not found."
Run: bash 4_linear_search.sh → Array: 10 20 30 40 50, Search: 30 → Found at index 2

