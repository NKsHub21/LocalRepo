10. Bubble Sort — 10_bubble_sort.sh
bash#!/bin/bash
read -p "Number of elements: " n
arr=()
for (( i=0; i<n; i++ )); do read -p "Element $((i+1)): " e; arr+=($e); done
echo "Before: ${arr[@]}"

for (( i=0; i<n-1; i++ )); do
    for (( j=0; j<n-i-1; j++ )); do
        if [ ${arr[$j]} -gt ${arr[$((j+1))]} ]; then
            temp=${arr[$j]}; arr[$j]=${arr[$((j+1))]}; arr[$((j+1))]=$temp
        fi
    done
done
echo "After:  ${arr[@]}"
Input: 64 25 12 22 11 90 → Output: 11 12 22 25 64 90

11. Prime Check + Reverse — 11_prime_reverse.sh
bash#!/bin/bash
read -p "Enter a number: " num

# Prime Check
is_prime=1
[ $num -lt 2 ] && is_prime=0
for (( i=2; i*i<=num; i++ )); do (( num%i==0 )) && is_prime=0 && break; done
[ $is_prime -eq 1 ] && echo "$num IS prime" || echo "$num is NOT prime"

# Reverse
rev=0; temp=$num
while [ $temp -gt 0 ]; do
    rev=$(( rev*10 + temp%10 )); temp=$(( temp/10 ))
done
echo "Reverse of $num = $rev"
17: IS prime, Reverse = 71 | 12: NOT prime, Reverse = 21

12. Substring Count via Args — 12_substring_count.sh
bash#!/bin/bash
# Usage: bash 12_substring_count.sh "main string" "sub"
main_str="$1"; sub_str="$2"
count=0; temp="$main_str"
while [[ "$temp" == *"$sub_str"* ]]; do
    temp="${temp#*$sub_str}"; (( count++ ))
done
echo "Substring '$sub_str' found $count time(s)"
